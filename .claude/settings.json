{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/check-file-naming.sh",
            "timeout": 5000
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/check-test-location.sh",
            "timeout": 5000
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/check-console-log.sh",
            "timeout": 5000
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/check-architecture-boundary.sh",
            "timeout": 5000
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/format-typescript.sh",
            "timeout": 15000
          }
        ]
      }
    ]
  }
}
