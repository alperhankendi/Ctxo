# Dependencies
node_modules/

# Build output
dist/

# Ctxo cache (never committed)
.ctxo/.cache/

# Ctxo index lives only at the monorepo root — any package-local .ctxo/ is
# a side effect of running cli with the wrong cwd during development
packages/*/.ctxo/

# cli ships root README + llms.txt via prepack; ignore the staged copies
packages/cli/README.md
packages/cli/llms.txt
packages/cli/llms-full.txt

# OS
.DS_Store
Thumbs.db

# IDE
.idea/
.vscode/
*.swp
*.swo

# Environment
.env
.env.*
!.env.example

# Coverage
coverage/

# Test results
test-results/

# Logs
*.log
npm-debug.log*

_bmad/*

# Session notes
todo.md
CLAUDE.local.md
_site/
headers.tmp
pages/docs/

# Brainstorming specs / design docs (local only, not committed)
docs/superpowers/

# BMAD framework (local tooling, not committed)
_bmad/
_bmad_output/

# Private notes (not for the public repo)
docs-private/

# Local agent tooling / worktrees
.claude/skills/
.claude/worktrees/

# Build caches
*.lscache
