{
  "name": "ctxo",
  "version": "0.1.0",
  "description": "MCP server delivering dependency-aware, history-enriched context for codebases",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "ctxo": "dist/index.js"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "mcp",
    "context",
    "ai",
    "coding-assistant",
    "dependency-graph"
  ],
  "author": "Alper Hankendi",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "chokidar": "^4.0.3",
    "simple-git": "^3.27.0",
    "sql.js": "^1.14.1",
    "ts-morph": "^25.0.0",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@types/node": "^22.15.3",
    "@vitest/coverage-v8": "^3.1.3",
    "eslint": "^9.26.0",
    "tsup": "^8.4.0",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.57.2",
    "vitest": "^3.1.3"
  }
}
