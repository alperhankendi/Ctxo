{
  "name": "ctxo-monorepo",
  "private": true,
  "version": "0.0.0",
  "description": "Ctxo monorepo workspace root — see packages/* for published packages",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "test:unit": "pnpm -r test:unit",
    "test:e2e": "pnpm -r test:e2e",
    "typecheck": "pnpm -r typecheck",
    "lint": "pnpm -r lint",
    "dev": "pnpm --filter @ctxo/cli dev",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "pnpm -r build && changeset publish"
  },
  "packageManager": "pnpm@10.9.0",
  "author": "Alper Hankendi",
  "license": "MIT",
  "devDependencies": {
    "@changesets/cli": "^2.30.0"
  }
}
