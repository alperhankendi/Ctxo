{
  "name": "@ctxo/cli",
  "version": "0.7.0",
  "description": "MCP server delivering dependency-aware, history-enriched context for codebases",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "ctxo": "dist/index.js"
  },
  "files": [
    "dist/",
    "pages/visualize-template.html",
    "README.md",
    "llms.txt",
    "llms-full.txt"
  ],
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsup",
    "prepack": "node -e \"const fs=require('fs');for(const f of ['README.md','llms.txt','llms-full.txt'])fs.copyFileSync('../../'+f,f)\"",
    "dev": "tsx src/index.ts",
    "test": "vitest run",
    "test:unit": "vitest run --config vitest.config.unit.ts",
    "test:unit:coverage": "vitest run --config vitest.config.unit.ts --coverage",
    "test:e2e": "vitest run --config vitest.config.e2e.ts",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "bench": "tsx benchmarks/benchmark-runner.ts"
  },
  "keywords": [
    "mcp",
    "context",
    "ai",
    "coding-assistant",
    "dependency-graph"
  ],
  "author": "Alper Hankendi",
  "license": "MIT",
  "dependencies": {
    "@clack/prompts": "^1.2.0",
    "@ctxo/plugin-api": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.12.1",
    "chokidar": "^5.0.0",
    "picocolors": "^1.1.1",
    "simple-git": "^3.27.0",
    "sql.js": "^1.14.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@ctxo/lang-csharp": "workspace:*",
    "@ctxo/lang-go": "workspace:*",
    "@ctxo/lang-typescript": "workspace:*",
    "@types/node": "^25.6.0",
    "@vitest/coverage-v8": "^4.1.4",
    "eslint": "^10.2.0",
    "tsup": "^8.4.0",
    "tsx": "^4.19.4",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.57.2",
    "vitest": "^4.1.4"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/alperhankendi/Ctxo.git",
    "directory": "packages/cli"
  },
  "bugs": {
    "url": "https://github.com/alperhankendi/Ctxo/issues"
  },
  "homepage": "https://github.com/alperhankendi/Ctxo#readme"
}
