{
  "name": "@ctxo/lang-csharp",
  "version": "0.7.2",
  "description": "Ctxo C# language plugin (Roslyn full tier, tree-sitter syntax fallback)",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist/",
    "tools/ctxo-roslyn/ctxo-roslyn.csproj",
    "tools/ctxo-roslyn/Program.cs",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:unit": "vitest run"
  },
  "keywords": [
    "ctxo",
    "ctxo-plugin",
    "language-plugin",
    "csharp",
    "dotnet",
    "roslyn",
    "tree-sitter"
  ],
  "author": "Alper Hankendi",
  "license": "MIT",
  "dependencies": {
    "tree-sitter": "^0.22.4",
    "tree-sitter-c-sharp": "^0.23.1"
  },
  "peerDependencies": {
    "@ctxo/plugin-api": "^0.7.1"
  },
  "devDependencies": {
    "@ctxo/plugin-api": "workspace:*",
    "@types/node": "^25.6.0",
    "tsup": "^8.4.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/alperhankendi/Ctxo.git",
    "directory": "packages/lang-csharp"
  },
  "bugs": {
    "url": "https://github.com/alperhankendi/Ctxo/issues"
  },
  "homepage": "https://github.com/alperhankendi/Ctxo#readme",
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
